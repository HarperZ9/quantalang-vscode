{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "BuildLang",
  "scopeName": "source.build",
  "fileTypes": ["bld"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#lifetimes" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#effect-keywords" },
    { "include": "#ai-keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#macros" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.build",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.build",
          "match": "//.*$"
        },
        {
          "name": "comment.block.documentation.build",
          "begin": "/\\*\\*(?!/)",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        },
        {
          "name": "comment.block.build",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.build",
          "begin": "#!?\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.attribute.build" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.attribute.build" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            {
              "name": "entity.name.tag.build",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.build",
          "begin": "b?\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.build" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.build" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.build",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]{1,6}\\}|.)"
            },
            {
              "name": "meta.interpolation.build",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#numbers" },
                {
                  "name": "variable.other.build",
                  "match": "[a-zA-Z_][a-zA-Z0-9_]*"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.raw.build",
          "begin": "b?r(#*)\"",
          "end": "\"\\1",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.build" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.build" }
          }
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.build",
          "match": "b?'([^'\\\\]|\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]{1,6}\\}|.))'"
        }
      ]
    },
    "lifetimes": {
      "patterns": [
        {
          "name": "storage.modifier.lifetime.build",
          "match": "'(static|[a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.build",
          "match": "\\b0x[0-9A-Fa-f_]+(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize)?\\b"
        },
        {
          "name": "constant.numeric.octal.build",
          "match": "\\b0o[0-7_]+(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize)?\\b"
        },
        {
          "name": "constant.numeric.binary.build",
          "match": "\\b0b[01_]+(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize)?\\b"
        },
        {
          "name": "constant.numeric.float.build",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?(f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.float.build",
          "match": "\\b[0-9][0-9_]*([eE][+-]?[0-9_]+)(f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.float.build",
          "match": "\\b[0-9][0-9_]*(f32|f64)\\b"
        },
        {
          "name": "constant.numeric.integer.build",
          "match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.build",
          "match": "\\b(if|else|match|loop|while|for|in|break|continue|return|do|try|yield)\\b"
        },
        {
          "name": "keyword.other.fn.build",
          "match": "\\bfn\\b"
        },
        {
          "name": "storage.type.build",
          "match": "\\b(struct|enum|trait|impl|type|union|const|static|let|mod|module|macro|macro_rules)\\b"
        },
        {
          "name": "storage.modifier.build",
          "match": "\\b(mut|pub|ref|move|box|unsafe|extern|dyn|async|await|where|abstract|final|override|priv|default|auto|become)\\b"
        },
        {
          "name": "keyword.other.build",
          "match": "\\b(use|as|crate|super|typeof|sizeof)\\b"
        },
        {
          "name": "variable.language.self.build",
          "match": "\\bself\\b"
        },
        {
          "name": "entity.name.type.self.build",
          "match": "\\bSelf\\b"
        }
      ]
    },
    "effect-keywords": {
      "patterns": [
        {
          "name": "keyword.other.effect.build",
          "match": "\\b(with|effect|handle|resume|perform)\\b"
        }
      ]
    },
    "ai-keywords": {
      "patterns": [
        {
          "name": "keyword.other.ai.build",
          "match": "\\b(ai|neural|infer)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.build",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.other.placeholder.build",
          "match": "\\b_\\b"
        },
        {
          "name": "constant.other.caps.build",
          "match": "\\b[A-Z][A-Z0-9_]+\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.build",
          "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char|str|String|Vec|Option|Result|Box|Rc|Arc|HashMap|HashSet|BTreeMap|BTreeSet)\\b"
        },
        {
          "name": "entity.name.type.build",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.build",
          "begin": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "end": "(?=[\\{;])",
          "beginCaptures": {
            "1": { "name": "keyword.other.fn.build" },
            "2": { "name": "entity.name.function.build" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#types" },
            { "include": "#lifetimes" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        },
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.build" }
          }
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.build",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*!)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.build",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=)"
        },
        {
          "name": "keyword.operator.comparison.build",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.build",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.build",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.bitwise.build",
          "match": "(&|\\||\\^|<<|>>|~)"
        },
        {
          "name": "keyword.operator.range.build",
          "match": "(\\.\\.=|\\.\\.\\.|\\.\\.)"
        },
        {
          "name": "keyword.operator.path.build",
          "match": "(::|->|=>|\\?)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.build",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.section.braces.build",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.build",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.build",
          "match": "[\\[\\]]"
        }
      ]
    }
  }
}
